# =============================================================================
# BukuWarung-AI — Environment Variables
# Salin ke .env:  copy .env.example .env
# =============================================================================

# --- Wajib (production) ---
OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
FONNTE_TOKEN=
GROQ_API_KEY=

# --- Model OpenRouter (opsional, ada default) ---
PRIMARY_MODEL=minimax/minimax-m3
BACKUP_MODEL=deepseek/deepseek-chat-v3
FREE_MODEL=qwen/qwen3-coder:free

# --- Server ---
HOST=0.0.0.0
PORT=8000
APP_NAME=BukuWarung-AI
DEBUG=false

# --- Admin agent: nomor WA owner (pisah koma) ---
OWNER_PHONES=6281234567890
