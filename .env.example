# =============================================================================
# laris.AI — Environment variables (SALIN ke kita-cuan-wa-bot/.env untuk bot)
# JANGAN commit file .env yang berisi nilai asli.
# =============================================================================

# --- Supabase (wajib) ---
SUPABASE_URL=https://xxxx.supabase.co

# Bot WA: pakai SERVICE_ROLE (Settings → API → service_role)
# Dashboard Streamlit: pakai ANON key di .streamlit/secrets.toml
SUPABASE_KEY=your-key-here

# --- Groq AI (wajib) ---
GROQ_API_KEY=gsk_xxx

# --- WhatsApp provider (bot saja) ---
WA_PROVIDER=fonnte
WA_API_KEY=token-fonnte-atau-wablas

# --- Logistik AI (opsional) ---
STOCK_THRESHOLD=10
REORDER_QTY=20

# Fallback user_id jika nomor belum di tabel wa_users (demo)
# WA_DEFAULT_USER_ID=
